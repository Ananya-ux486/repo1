# Copy to .env and fill secrets. Never commit .env.

MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/tasmafiveDB?retryWrites=true&w=majority
MONGODB_ADMIN_URI=mongodb+srv://USER:PASSWORD@HOST/tasmafiveAdminDB?retryWrites=true&w=majority
AUTH_SECRET=tasmafive-dev-auth-secret-change-me
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
