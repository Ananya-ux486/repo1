{
  "name": "tasmafive-monorepo",
  "private": true,
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cargo run --manifest-path backend/Cargo.toml",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "cargo build --release --manifest-path backend/Cargo.toml",
    "check:backend": "cargo check --manifest-path backend/Cargo.toml",
    "lint:frontend": "npm --prefix frontend run lint"
  }
}
