# Copy to .env for server/runtime values and optionally .env.local for
# browser-exposed NEXT_PUBLIC_* values. Never commit real credentials.

NODE_ENV=development
# The unified server defaults to 3000. Hosting providers normally inject PORT.
PORT=3000

MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/tasmafiveDB?retryWrites=true&w=majority
AUTH_SECRET=replace-with-a-unique-random-secret-at-least-32-characters

# Public browser configuration
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# Email and local-only OTP development
# Local clone without Resend: keep ALLOW_DEMO_OTP=true (OTP shows in UI).
# Production: set RESEND_API_KEY and ALLOW_DEMO_OTP=false.
RESEND_API_KEY=
AUTH_FROM_EMAIL=TasmaFive <onboarding@resend.dev>
ALLOW_DEMO_OTP=true
PROJECTS_ADMIN_EMAIL=replace-project-admin@example.com
PROJECTS_ADMIN_PASSWORD=replace-with-a-unique-strong-password
PROJECTS_ADMIN_NOTIFY_EMAIL=replace-notification-address@example.com
PROJECTS_TEAM_CODE=replace-with-a-unique-random-team-code

# Optional Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Exact public origins and callback base URLs
ALLOWED_ORIGINS=http://localhost:3000,https://project.tasmafivesolutions.com
PUBLIC_SITE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3000

# Payment providers
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
CCAVENUE_ENV=test
CCAVENUE_MERCHANT_ID=
CCAVENUE_ACCESS_CODE=
CCAVENUE_WORKING_KEY=
