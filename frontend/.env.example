# Copy to .env.local for local secrets

# tawk.to AI Chatbot (frontend only — no custom chat API)
NEXT_PUBLIC_TAWK_PROPERTY_ID=6a5e3e8f1a1df41d5c178534
NEXT_PUBLIC_TAWK_WIDGET_ID=1ju028oi0

# Must match server/.env AUTH_SECRET
AUTH_SECRET=tasmafive-dev-auth-secret-change-me

# Resend (contact / quote / auth emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@tasmafivesolutions.com

# Instagram Graph API (optional)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Admin (Express /api/auth/admin-login)
PROJECTS_ADMIN_EMAIL=admin@tasmafivesolutions.com
PROJECTS_ADMIN_PASSWORD=Admin@TasmaFive

# Express API (default http://localhost:8080)
# API_BACKEND_URL=http://localhost:8080
# USE_API_PROXY=0
