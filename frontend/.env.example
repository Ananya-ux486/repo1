# Copy to .env.local for local secrets (optional — site works without these)

# Resend (contact / quote / auth emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@tasmafivesolutions.com

# Instagram Graph API (optional — falls back to local posts in src/data/instagramPosts.ts)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Auth / projects admin (optional)
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# tawk.to AI Chatbot — get these from your tawk.to dashboard
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
